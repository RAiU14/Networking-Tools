# Cisco EOX Manager Docker defaults.
# Copy this file to .env before editing:
#   cp .env.example .env

# API runtime database. The API container reaches Docker PostgreSQL at postgres:5432.
# Beginners can also configure SQLite/PostgreSQL from the GUI without editing this file.
EOX_DATABASE_URL=postgresql+psycopg://eox_user:eox_password@postgres:5432/eox_cache

# Docker PostgreSQL defaults. The host port defaults to 5433 to avoid conflicts with
# system PostgreSQL on host port 5432.
EOX_POSTGRES_USER=eox_user
EOX_POSTGRES_PASSWORD=eox_password
EOX_POSTGRES_DB=eox_cache
EOX_POSTGRES_HOST_PORT=5433

# Public host ports. Set EOX_FRONTEND_HOST_PORT=5174 if 5173 is already busy.
EOX_API_HOST_PORT=8000
EOX_FRONTEND_HOST_PORT=5173

# Runtime state, DB selection, and logs inside the backend container.
EOX_DATA_DIR=/product/data
EOX_LOG_DIR=/product/logs

# CORS: the regex allows HTTP origins on 5173 and 5174 for localhost, LAN, and Tailscale hosts.
# To lock this down, set EOX_CORS_ORIGIN_REGEX empty and list exact origins in EOX_CORS_ORIGINS.
EOX_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
EOX_CORS_ORIGIN_REGEX=^https?://([^/:]+)(:5173|:5174)

# Optional: stable Fernet key for encrypting Cisco API credentials saved from the GUI.
# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# EOX_SECRET_KEY=

# Optional Cisco API defaults. The GUI setup screen can save these later.
# CISCO_CLIENT_ID=
# CISCO_CLIENT_SECRET=
# CISCO_ACCESS_TOKEN=
CISCO_API_BASE_URL=https://apix.cisco.com
CISCO_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token

# Optional API protection. Leave disabled for a private LAN trial.
# You can create/enable a token from the GUI Security panel without editing this file.
EOX_AUTH_ENABLED=false

# Built-in in-memory rate limits. These protect small servers from accidental loops.
EOX_RATE_LIMIT_ENABLED=true
EOX_RATE_LIMIT_READ_PER_MINUTE=240
EOX_RATE_LIMIT_WRITE_PER_MINUTE=60
EOX_RATE_LIMIT_AUTOPOP_JOBS_PER_HOUR=12

# v18 scaling / worker options.
# Use 1-2 API workers on old home servers. More workers use more RAM.
EOX_API_WORKERS=1

# local = API process also runs Auto_Pop jobs.
# external = API only queues jobs; start the worker profile to process jobs.
EOX_AUTOPOP_EXECUTION_MODE=local
EOX_AUTOPOP_WORKER_POLL_SECONDS=5

# GraphQL guardrails for flexible API users.
EOX_GRAPHQL_LIMITS_ENABLED=true
EOX_GRAPHQL_MAX_QUERY_CHARS=20000
EOX_GRAPHQL_MAX_DEPTH=10
